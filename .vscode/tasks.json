{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build (build.py)",
            "detail": "Create/refresh .venv-build and run PyInstaller via build.py",
            "type": "process",
            "command": "${command:python.interpreterPath}",
            "args": ["build.py"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        }
    ]
}
