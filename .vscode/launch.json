{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Hagibis Monitor",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "windows": {
                "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
            },
            "linux": {
                "python": "${workspaceFolder}/.venv/bin/python"
            },
            "osx": {
                "python": "${workspaceFolder}/.venv/bin/python"
            }
        }
    ]
}
